{
  "manifest_version": 3,
  "name": "Toca WhatsApp Connector",
  "version": "2.1.1",
  "description": "Botón discreto para vincular chats de WhatsApp Web con tu Dashboard local de Toca",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "https://*.whatsapp.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.whatsapp.com/*"
      ],
      "js": ["content_whatsapp.js"],
      "run_at": "document_end"
    }
  ]
}
